# syntax=docker/dockerfile:1

FROM golang:1.26-alpine AS go-build

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY cmd ./cmd
COPY internal ./internal
COPY pkg ./pkg
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/sideplane-sidecar ./cmd/sideplane-sidecar

FROM alpine:3 AS runtime

RUN apk add --no-cache ca-certificates

COPY --from=go-build /out/sideplane-sidecar /usr/local/bin/sideplane-sidecar

CMD ["sideplane-sidecar"]
