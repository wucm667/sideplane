# Example environment file for read-only sidecar testing.
#
# Install as /etc/sideplane/sideplane-sidecar.env and adjust values.

SIDEPLANE_SERVER_URL=http://sideplane.example.test:8080
SIDEPLANE_NODE_ID=test-node-1
SIDEPLANE_SIDECAR_STATE=/var/lib/sideplane/sidecar.json
SIDEPLANE_HEARTBEAT_INTERVAL=30s
SIDEPLANE_JOB_POLL_INTERVAL=30s

# Read-only config discovery paths. Live writes still require the explicit
# sideplane-sidecar --allow-live-apply flag and reviewed systemd write paths.
SIDEPLANE_HERMES_CONFIG_PATHS=/etc/hermes/config.yaml
SIDEPLANE_OPENCLAW_CONFIG_PATHS=/etc/openclaw/config.yaml
SIDEPLANE_APPLY_WORK_DIR=/var/lib/sideplane/apply
