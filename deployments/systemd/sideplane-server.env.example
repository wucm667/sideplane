# Example environment file for the Sideplane server.
#
# Install as /etc/sideplane/sideplane-server.env and adjust values.

SIDEPLANE_ADDR=:8080
SIDEPLANE_DB_PATH=/var/lib/sideplane/sideplane.db
SIDEPLANE_WEB_DIR=/usr/share/sideplane/web
# Set SIDEPLANE_OPERATOR_TOKEN to a long random secret before exposing the server.
SIDEPLANE_OPERATOR_TOKEN=
SIDEPLANE_SIGNING_KEY=/var/lib/sideplane/signing.key
