# Example environment file for the Sideplane server.
#
# Install as /etc/sideplane/sideplane-server.env and adjust values.

SIDEPLANE_ADDR=:8080
SIDEPLANE_DB_PATH=/var/lib/sideplane/sideplane.db
# Optional direct TLS termination. Set both cert and key, or leave both unset
# and terminate TLS at a reverse proxy.
# SIDEPLANE_TLS_CERT=/etc/sideplane/tls/server.crt
# SIDEPLANE_TLS_KEY=/etc/sideplane/tls/server.key
# Optional HTTP listener that redirects to the HTTPS SIDEPLANE_ADDR.
# Requires SIDEPLANE_TLS_CERT and SIDEPLANE_TLS_KEY.
# SIDEPLANE_TLS_REDIRECT_ADDR=:8080
# Set SIDEPLANE_OPERATOR_TOKEN to a long random secret before exposing the server.
SIDEPLANE_OPERATOR_TOKEN=
SIDEPLANE_SIGNING_KEY=/var/lib/sideplane/signing.key
SIDEPLANE_HEARTBEAT_RETENTION=100
SIDEPLANE_JOB_RETENTION=720h
SIDEPLANE_AUDIT_RETENTION=4320h

# Optional development override. Leave unset in production to use embedded Web UI assets.
# SIDEPLANE_WEB_DIR=/path/to/web/dist
